    { "duration": 240, "power": 280, "note": "interval 1 — VO2max" },
    { "duration": 240, "power": 120, "note": "recovery 1" },

    { "duration": 240, "power": 280, "note": "interval 2 — VO2max" },
    { "duration": 240, "power": 120, "note": "recovery 2" },

    { "duration": 240, "power": 280, "note": "interval 3 — VO2max" },
    { "duration": 240, "power": 120, "note": "recovery 3" },

    { "duration": 240, "power": 280, "note": "interval 4 — VO2max" },
    { "duration": 240, "power": 120, "note": "recovery 4" },

    { "duration": 600, "power": 120, "type": "ramp", "note": "cool-down" }
  ]
}
